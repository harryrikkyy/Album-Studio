<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Electron needs the JIT / unsigned-memory entitlements under the
         hardened runtime, otherwise the app crashes on launch once signed. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- The Tools Bar docks to Photoshop by sending Apple events to
         System Events / Photoshop via osascript. Without this entitlement
         the hardened runtime blocks the automation and the bar can never
         read Photoshop's window bounds (it just floats). -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
