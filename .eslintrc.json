{
  "env": {
    "node": true,
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-redeclare": "error",
    "no-undef": "error",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-prototype-builtins": "off",
    "no-inner-declarations": "off",
    "no-extra-semi": "off",
    "prefer-const": "warn"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "scripts/**/*.jsx",
    "src/index.html",
    "src/login.html"
  ]
}
