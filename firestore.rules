// ─────────────────────────────────────────────────────────────────────────────
// Firestore Security Rules — Creative Hubb Album Toolkit Pro
//
// Deploy via: firebase deploy --only firestore:rules --project creative-hubb-toolkit
// (or Firebase Console → Firestore Database → Rules → Publish).
//
// HOW THE APP AUTHENTICATES (updated)
//   The desktop app now signs IN to Firebase: it takes the Google `id_token`
//   from OAuth and exchanges it (Identity Toolkit) for a real Firebase session,
//   then sends the Firebase idToken as a Bearer token on every Firestore
//   request. So `request.auth` is populated and carries the user's email.
//   That lets us scope reads to each user's OWN record — no more `read: if true`.
//
//   The OWNER's admin panel authenticates (Firebase Auth) as
//   creativehubb2@gmail.com and has full write access here.
//
// APP OPERATIONS (all verified against these rules):
//   - New-user first login : create own doc {email,name,photoURL,lastLogin,activated:false}
//   - Returning-user login : update own {name,photoURL,lastLogin}
//   - Machine lock         : set own {machineId,machineName} when unbound
//   - License check        : read own doc
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {

      // READ (single doc): a user may read ONLY their own record; owner reads any.
      allow get: if request.auth != null
                 && (request.auth.token.email == resource.data.email
                     || request.auth.token.email == "creativehubb2@gmail.com");

      // LIST (enumerate the whole collection): owner only — the admin panel.
      // This is what closes bulk customer-list harvesting.
      allow list: if request.auth != null
                  && request.auth.token.email == "creativehubb2@gmail.com";

      // OWNER: full write access — activate, set expiry, store the signature,
      // move machine, delete. The ONLY path that changes activated/expiresOn/sig.
      allow write: if request.auth != null
                   && request.auth.token.email == "creativehubb2@gmail.com";

      // NEW USER: the app may create its OWN record, but NEVER pre-activated and
      // NEVER with an expiry (closes the self-activation / free-license bypass).
      allow create: if request.auth != null
                    && request.auth.token.email == request.resource.data.email
                    && request.resource.data.activated == false
                    && !("expiresOn" in request.resource.data);

      // RETURNING USER: the app may update its OWN login/machine details, but:
      //   - cannot touch activated / expiresOn / sig / lic* (payment integrity)
      //   - cannot change the account's email               (identity)
      //   - may only claim machineId when it is currently unbound (anti-theft);
      //     the owner can still re-assign the machine via the owner rule above.
      allow update: if request.auth != null
                    && request.auth.token.email == resource.data.email
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['activated', 'expiresOn', 'email', 'sig', 'licExpiresOn', 'licActivatedOn'])
                    && (
                         resource.data.machineId == null
                      || resource.data.machineId == ''
                      || request.resource.data.machineId == resource.data.machineId
                    );
    }
  }
}
